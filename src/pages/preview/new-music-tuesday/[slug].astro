---
import '../../../styles/global.css';
import HTML from '../../../layouts/html.astro';
import Blocks from '../../../components/blocks/_blocks.astro';
import { getNewMusicTuesdayBySlug } from '../../../lib/content/newMusicTuesdayCollection';

export const prerender = false;

const issue = await getNewMusicTuesdayBySlug(Astro.params.slug ?? '', {
	preview: true
});
if (!issue) {
	Astro.response.status = 404;
}

const title = issue?.title ?? 'Preview not found';
const description = issue
	? 'New Music Tuesday issue preview'
	: 'The requested issue preview was not found.';
---

{
	issue ? (
		<HTML title={title} description={description}>
			<div class="min-h-screen bg-[#090b12] text-white">
				<div class="mx-auto max-w-6xl space-y-8 px-6 pb-12">
					<Blocks blockData={issue.blocks} />
				</div>
			</div>
		</HTML>
	) : (
		<HTML title={title} description={description}>
			<div class="mx-auto max-w-3xl px-6 py-14 text-stone-700">
				Preview issue not found.
			</div>
		</HTML>
	)
}
